# vstack — Environment Variables
# Copy this to .env and fill in your keys:
#   cp .env.template .env

# ── Required ──────────────────────────────────────────────────────────

# ElevenLabs API key for TTS narration and music generation
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── Optional (have defaults or use gcloud login) ─────────────────────

# Google Cloud project ID (for Vertex AI video analysis)
# If not set, uses the value from vstack.config.json
GCP_PROJECT=

# Google Cloud SDK path (if not on PATH)
# Example: C:\Users\you\AppData\Local\Google\Cloud SDK\google-cloud-sdk\bin
GCLOUD_PATH=

# Anthropic API key (for scan-targeted.mjs smile/pattern detection)
# Only needed if using Anthropic vision instead of Gemini
ANTHROPIC_API_KEY=

# Directory containing source video files
# Example: C:\Star Trek  or  /home/user/movies
MEDIA_DIR=

# Budget limit in USD — warns when estimated spend exceeds this
BUDGET_LIMIT_USD=100
