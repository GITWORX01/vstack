# Required: Google Cloud Project ID (for Vertex AI Gemini)
# Run: gcloud auth login && gcloud config set project YOUR_PROJECT
GCP_PROJECT=

# Required: Google Cloud Storage bucket (for low-res video uploads)
GCS_BUCKET=gs://your-bucket-name

# Required: Path to source video files
MEDIA_DIR=

# Optional: TTS narration (ElevenLabs)
ELEVENLABS_API_KEY=

# Optional: Google Cloud SDK path (auto-detected on most systems)
# GCLOUD_PATH=

# Optional: Default region (us-east1, us-central1, us-west1, us-west4, europe-west1)
# GCP_REGION=us-east1

# Optional: Budget limit before warnings (default: $100)
# BUDGET_LIMIT_USD=100
